# Decifer Learning — environment variables
# Copy to .env.local for local development. Never commit real secrets.
# Source of truth: CLAUDE.md §6.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Prisma / Postgres ---
# Pooled connection (used at runtime by the app)
DATABASE_URL=
# Direct connection — required by Prisma when Supabase pooler is in front (migrations)
DIRECT_URL=

# --- LLM / embeddings ---
# Anthropic Claude — content generation, consensus, constitutional critique
ANTHROPIC_API_KEY=
# OpenAI — embeddings for RAG + dedup. Omit only if using a local embedding model.
OPENAI_API_KEY=

# --- App + microservice ---
# Python FastAPI URL on Cloud Run (content pipeline worker). Server-only — must not
# be exposed to the browser. The Next.js app proxies via /api/pipeline/*.
PIPELINE_SERVICE_URL=
# Phase 8A — temporary admin gate for /api/pipeline/* until role-based admin
# promotion lands in Phase 12. Allows curl-driven triggering via x-admin-token
# header. Leave blank in environments where signed-in admin role is enough.
ADMIN_PIPELINE_TOKEN=
# Canonical site URL — used for PWA + share links
NEXT_PUBLIC_APP_URL=
