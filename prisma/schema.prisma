// Decifer Learning — Prisma schema
// Source of truth: CLAUDE.md v2 §7. Do not rename tables/fields.
// CHECK constraints are modelled as PostgreSQL enums (Role, ContentStatus, Tier).
// Supabase manages auth.users — no parallel custom users table.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector, pgcrypto]
}

// ---------- Enums (replace CHECK constraints) ----------

enum Role {
  child
  parent
  admin
}

enum ContentStatus {
  staged
  published
  flagged
  regenerating
}

enum Tier {
  sprout
  explorer
  lightning
}

// ---------- Identity & family ----------

model Profile {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                String    @unique @db.Uuid // FK to auth.users (Supabase-managed)
  display_name           String
  avatar_config          Json?
  theme_name             String?
  year_group_id          String?   @db.Uuid
  role                   Role      @default(child)
  total_points           Int       @default(0)
  streak_days            Int       @default(0)
  last_active            DateTime?
  sr_easiness            Float     @default(2.5)
  dashboard_widgets      Json?
  study_buddy            String?
  accessibility_settings Json?
  // First-run onboarding: set once the child has seen the avatar + about-me
  // prompt (whether they completed or skipped it) so we never nag again.
  onboarded_at           DateTime?
  // Non-PII personalisation answers captured at onboarding (favourite subject,
  // interests, preferred learning styles, self-rated confidence). Editable later.
  learning_profile       Json?
  // GDPR/UK Children's Code: for child accounts, records when the parent gave
  // explicit consent and which parent's user_id gave it.
  parental_consent_at    DateTime?
  consented_by_user_id   String?   @db.Uuid
  // KS4 only: 'AQA' | 'Edexcel' | 'OCR'. Null for KS1–KS3.
  exam_board             String?
  // Parent/guardian contact captured at child self-registration. The parent
  // confirms via an emailed link (/verify-parent?token=…); reminders go out
  // via /api/cron/parent-verify until verified (max 3 reminders).
  parent_email                 String?
  parent_email_verified_at     DateTime?
  parent_verify_token          String?   @unique @db.Uuid
  parent_verify_sent_at        DateTime?
  parent_verify_reminder_count Int       @default(0)
  // Last child-initiated year-group change — drives the self-service cooldown.
  year_group_changed_at        DateTime?
  // Denormalised subscription tier for fast gating — kept in sync by webhook.
  subscription_tier      String    @default("free")
  created_at             DateTime  @default(now())

  year_group       YearGroup?       @relation(fields: [year_group_id], references: [id])
  family_as_parent FamilyLink[]     @relation("ParentLink")
  family_as_child  FamilyLink[]     @relation("ChildLink")
  parent_controls  ParentControl?
  point_events     PointEvent[]
  profile_badges   ProfileBadge[]
  streak_shield    StreakShield?
  collection       ChildCollection[]
  topic_progress   TopicProgress[]
  quiz_attempts    QuizAttempt[]
  session_answers  SessionAnswer[]
  child_missions   ChildMission[]
  quiz_reflections QuizReflection[]

  // PLI v1
  learning_events                 LearningEvent[]

  // Reward Vault
  vault_status                    ChildVaultStatus?
  vault_milestone_events          VaultMilestoneEvent[]
  reward_requests_as_child        RewardRequest[]        @relation("ChildRewardRequests")
  reward_requests_as_parent       RewardRequest[]        @relation("ParentRewardRequests")
  reward_requests_responded       RewardRequest[]        @relation("RespondedByProfile")
  vault_parent_settings_as_parent VaultParentSettings[]  @relation("ParentVaultSettings")
  vault_parent_settings_as_child  VaultParentSettings[]  @relation("ChildVaultSettings")
  question_reports                QuestionReport[]
  exploration_sessions            ExplorationSession[]
  exam_assignments_as_parent      ExamAssignment[]       @relation("ParentExamAssignments")
  exam_assignments_as_child       ExamAssignment[]       @relation("ChildExamAssignments")
  exam_attempts                   ExamAttempt[]

  @@map("profiles")
}

model FamilyLink {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parent_user_id String   @db.Uuid
  child_user_id  String   @db.Uuid
  linked_at      DateTime @default(now())
  seen_by_child  Boolean  @default(false)

  parent Profile @relation("ParentLink", fields: [parent_user_id], references: [user_id])
  child  Profile @relation("ChildLink", fields: [child_user_id], references: [user_id])

  @@unique([parent_user_id, child_user_id])
  @@unique([child_user_id]) // a child can only have one parent
  @@map("family_links")
}

model ParentControl {
  child_profile_id         String   @id @db.Uuid
  daily_time_limit_minutes Int      @default(60)
  allowed_time_start       DateTime? @db.Time
  allowed_time_end         DateTime? @db.Time
  leaderboard_visible      Boolean  @default(true)
  social_features_enabled  Boolean  @default(false)

  child Profile @relation(fields: [child_profile_id], references: [id])

  @@map("parent_controls")
}

// ---------- Curriculum structure ----------

model YearGroup {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  label     String @unique
  key_stage String

  profiles         Profile[]
  topics           Topic[]
  zones            Zone[]
  daily_challenges DailyChallenge[]
  curriculum_units CurriculumUnit[]
  exam_assignments ExamAssignment[]

  @@map("year_groups")
}

model Subject {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String  @unique
  colour_token String
  slug         String? @unique

  topics               Topic[]
  zones                Zone[]
  cards                CardCatalog[]
  curriculum_outcomes  CurriculumOutcome[]
  lessons              Lesson[]
  curriculum_units     CurriculumUnit[]
  exam_assignments     ExamAssignment[]

  @@map("subjects")
}

model Topic {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subject_id     String  @db.Uuid
  year_group_id  String  @db.Uuid
  title          String
  order_index    Int     @default(0)
  is_published   Boolean @default(false)
  zone_id        String? @db.Uuid
  slug           String?
  // When true this topic has no quiz — world map shows a book icon, Quiz button hidden.
  quiz_optional  Boolean @default(false)
  // 'instruction_first' (default Learn→Practise→Quiz) or 'pretest_first' (attempt→explanation→practise)
  pedagogy_mode  String  @default("instruction_first")

  subject               Subject             @relation(fields: [subject_id], references: [id])
  year_group            YearGroup           @relation(fields: [year_group_id], references: [id])
  zone                  Zone?               @relation(fields: [zone_id], references: [id])
  curriculum_units      CurriculumUnit[]
  learn_content         LearnContent[]
  practice_games        PracticeGame[]
  quiz_questions        QuizQuestion[]
  world_map_nodes       WorldMapNode[]      @relation("NodeTopic")
  unlocks_for_nodes     WorldMapNode[]      @relation("UnlockedByTopic")
  topic_progress        TopicProgress[]
  quiz_attempts         QuizAttempt[]
  missions              ChildMission[]
  curriculum_outcomes   CurriculumOutcome[]
  lessons               Lesson[]
  quiz_reflections      QuizReflection[]

  @@unique([subject_id, slug])
  @@map("topics")
}

model Zone {
  id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  year_group_id    String  @db.Uuid
  subject_id       String  @db.Uuid
  name             String
  theme            String?
  illustration_url String?
  guardian_quiz_id String? @db.Uuid

  year_group      YearGroup       @relation(fields: [year_group_id], references: [id])
  subject         Subject         @relation(fields: [subject_id], references: [id])
  topics          Topic[]
  world_map_nodes WorldMapNode[]

  @@map("zones")
}

model CurriculumUnit {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subject_id     String   @db.Uuid
  year_group_id  String   @db.Uuid
  topic_id       String?  @db.Uuid                   // the broad topic this unit belongs to
  title          String                               // Oak unit title, verbatim
  description    String?                              // enquiry question / subtitle
  order_index    Int      @default(0)                 // Oak teaching sequence
  oak_unit_slug  String?  @unique                     // traceability back to Oak API
  oak_confidence String?                              // 'high' | 'medium' | 'low'
  content_json   Json?                                // Oak lesson summary (key learning points, keywords, misconceptions) — ingested on the droplet, served from DB
  content_fetched_at DateTime?                        // when content_json was last refreshed from Oak
  created_at     DateTime @default(now())

  subject     Subject    @relation(fields: [subject_id], references: [id])
  year_group  YearGroup  @relation(fields: [year_group_id], references: [id])
  topic       Topic?     @relation(fields: [topic_id], references: [id])

  @@index([subject_id, year_group_id, order_index])
  @@index([topic_id])
  @@map("curriculum_units")
}

model WorldMapNode {
  id                   String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  zone_id              String  @db.Uuid
  topic_id             String  @db.Uuid
  x_pos                Float
  y_pos                Float
  unlocked_by_topic_id String? @db.Uuid

  zone        Zone   @relation(fields: [zone_id], references: [id])
  topic       Topic  @relation("NodeTopic", fields: [topic_id], references: [id])
  unlocked_by Topic? @relation("UnlockedByTopic", fields: [unlocked_by_topic_id], references: [id])

  @@map("world_map_nodes")
}

// ---------- Content ----------

model LearnContent {
  id                   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  topic_id             String        @db.Uuid
  body_html            String
  examples_json        Json?
  foundation_audio_url String?
  // Raster figures ({url, alt?, caption?}[]) — SVG-first escape hatch for photos
  // and complex artwork the diagram registry can't draw. See components/learn/LearnFigures.tsx.
  foundation_images    Json?         @default("[]")
  status               ContentStatus @default(staged)
  // Phase 11A provenance fields
  confidence_score     Float?
  source_chunk_ids     Json?
  generator_version    String?
  published_at         DateTime?

  topic Topic @relation(fields: [topic_id], references: [id])

  @@map("learn_content")
}

model PracticeGame {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  topic_id    String        @db.Uuid
  game_type   String
  config_json Json
  // Phase 11A: published gate for child-facing queries
  status      ContentStatus @default(staged)

  topic Topic @relation(fields: [topic_id], references: [id])

  @@map("practice_games")
}

model QuizQuestion {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  topic_id          String        @db.Uuid
  tier              Tier
  question_text     String
  question_type     String
  correct_answer    String
  distractors       Json
  hint_1            String?
  hint_2            String?
  hint_3            String?
  explanation       String?
  worked_example    String?       // Step-by-step solution of a similar problem; shown before child attempts
  foundation_images Json?
  confidence_score  Float?
  status            ContentStatus @default(staged)
  source_chunk_ids  Json?
  created_at        DateTime      @default(now())
  // Exam technique layer (Sprint 1)
  technique_type    String?   // 'recall' | 'perspective' | 'evidence_cite' | 'show_working' | 'two_part' | 'causation'
  technique_hint    String?   // fires before hint_1 on first wrong answer; teaches HOW to answer, not content
  technique_note    String?   // shown in post-answer explanation; reinforces technique used
  // Multi-part question types (Sprint 3)
  // true_false_grid: [{statement: string, correct: boolean}]
  // ordered_list:    [{item: string}]  (stored in correct order; component shuffles for display)
  answer_parts      Json?
  // Source analysis question type (Sprint 4)
  // source_text holds the primary source excerpt rendered above the question
  // source_label identifies the source: "Source A — medieval chronicle, 1350"
  // source_type classifies format: 'quote' | 'table' | 'graph_description'
  source_text       String?
  source_label      String?
  source_type       String?
  // Phase 11A provenance fields
  question_metadata Json?
  generator_version String?
  verifier_version  String?
  published_at      DateTime?

  topic           Topic           @relation(fields: [topic_id], references: [id])
  quiz_answers    QuizAnswer[]
  session_answers SessionAnswer[]
  reports         QuestionReport[]

  @@index([topic_id, status, tier])
  @@map("quiz_questions")
}

// ---------- Pipeline tracking (Phase 11A) ----------

model PipelineRun {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  run_type         String
  year_group       String
  subject          String
  topic_id         String?   @db.Uuid
  tier             String?
  status           String    @default("running")
  items_attempted  Int       @default(0)
  items_published  Int       @default(0)
  items_staged     Int       @default(0)
  items_failed     Int       @default(0)
  error_log        Json      @default("[]")
  started_at       DateTime  @default(now())
  completed_at     DateTime?
  pipeline_version String?

  generation_errors GenerationError[]

  @@map("pipeline_runs")
}

model GenerationError {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pipeline_run_id  String?  @db.Uuid
  topic_id         String?  @db.Uuid
  question_type    String?
  tier             String?
  stage_failed     Int?
  error_message    String
  raw_llm_output   Json?
  created_at       DateTime @default(now())

  pipeline_run PipelineRun? @relation(fields: [pipeline_run_id], references: [id])

  @@map("generation_errors")
}

// ---------- Gamification ----------

model PointEvent {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id String   @db.Uuid
  amount     Int
  reason     String
  created_at DateTime @default(now())

  profile Profile @relation(fields: [profile_id], references: [id])

  @@index([profile_id, created_at])
  @@map("point_events")
}

model Badge {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String  @unique
  icon_url     String?
  description  String?
  trigger_rule Json

  profile_badges ProfileBadge[]

  @@map("badges")
}

model ProfileBadge {
  profile_id String   @db.Uuid
  badge_id   String   @db.Uuid
  awarded_at DateTime @default(now())

  profile Profile @relation(fields: [profile_id], references: [id])
  badge   Badge   @relation(fields: [badge_id], references: [id])

  @@id([profile_id, badge_id])
  @@map("profile_badges")
}

model StreakShield {
  profile_id String @id @db.Uuid
  quantity   Int    @default(0)

  profile Profile @relation(fields: [profile_id], references: [id])

  @@map("streak_shields")
}

// ---------- Discovery Cards ----------

model CardCatalog {
  id                   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subject_id           String?       @db.Uuid
  year_group_id        String?       @db.Uuid
  rarity               String
  title                String
  fact_text            String
  illustration_url     String?
  source_url           String?
  is_seasonal          Boolean       @default(false)
  available_until      DateTime?
  is_fusion            Boolean       @default(false)
  required_subject_ids Json?
  status               ContentStatus @default(staged)

  subject            Subject?          @relation(fields: [subject_id], references: [id])
  collection_entries ChildCollection[]

  @@map("card_catalog")
}

model ChildCollection {
  profile_id        String   @db.Uuid
  card_id           String   @db.Uuid
  quantity          Int      @default(1)
  first_obtained_at DateTime @default(now())

  profile Profile     @relation(fields: [profile_id], references: [id])
  card    CardCatalog @relation(fields: [card_id], references: [id])

  @@id([profile_id, card_id])
  @@map("child_collection")
}

// ---------- Progress ----------

model TopicProgress {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id       String    @db.Uuid
  topic_id         String    @db.Uuid
  status           String
  last_score       Float?
  completed_at     DateTime?
  sr_repetitions   Int       @default(0)
  sr_interval_days Int       @default(1)
  sr_next_review   DateTime? @db.Date

  profile Profile @relation(fields: [profile_id], references: [id])
  topic   Topic   @relation(fields: [topic_id], references: [id])

  @@unique([profile_id, topic_id])
  @@map("topic_progress")
}

model QuizAttempt {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id         String   @db.Uuid
  topic_id           String   @db.Uuid
  score              Float
  hints_used         Int      @default(0)
  time_taken_seconds Int      @default(0)
  hearts_remaining   Int      @default(3)
  created_at         DateTime @default(now())

  profile Profile      @relation(fields: [profile_id], references: [id])
  topic   Topic        @relation(fields: [topic_id], references: [id])
  answers QuizAnswer[]

  @@map("quiz_attempts")
}

// OIT reflection — "What did you figure out today?"
// Organismic Integration Theory: helps children internalise the value of learning
// rather than just enjoying the app session. No edtech platform has this.
model QuizReflection {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id String   @db.Uuid
  topic_id   String   @db.Uuid
  text       String
  created_at DateTime @default(now())

  profile Profile @relation(fields: [profile_id], references: [id])
  topic   Topic   @relation(fields: [topic_id], references: [id])

  @@map("quiz_reflections")
}

model QuizAnswer {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attempt_id   String  @db.Uuid
  question_id  String  @db.Uuid
  child_answer String?
  was_correct  Boolean
  hint_number  Int     @default(0)
  time_seconds Int     @default(0)

  attempt  QuizAttempt  @relation(fields: [attempt_id], references: [id])
  question QuizQuestion @relation(fields: [question_id], references: [id])

  @@map("quiz_answers")
}

model SessionAnswer {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id  String   @db.Uuid
  question_id String   @db.Uuid
  was_correct Boolean
  tier        Tier
  created_at  DateTime @default(now())

  profile  Profile      @relation(fields: [profile_id], references: [id])
  question QuizQuestion @relation(fields: [question_id], references: [id])

  @@index([profile_id, created_at])
  @@map("session_answers")
}

// ---------- Missions ----------

model ChildMission {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id      String    @db.Uuid
  mission_type    String
  target_topic_id String?   @db.Uuid
  target_tier     Tier?
  target_value    Int?
  current_value   Int       @default(0)
  created_at      DateTime  @default(now())
  completed_at    DateTime?

  profile Profile @relation(fields: [profile_id], references: [id])
  topic   Topic?  @relation(fields: [target_topic_id], references: [id])

  @@map("child_missions")
}

// ---------- Phase 2: Past papers ----------

model PastPaperQuestion {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  exam_board         String
  subject            String
  year               Int
  paper_number       Int
  question_number    Int
  question_text      String
  question_image_url String?
  marks_available    Int
  mark_scheme        Json
  topic_tag          String[]

  @@map("past_paper_questions")
}

// ---------- RAG knowledge base ----------

model CurriculumChunk {
  id          String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subject     String
  year_group  String
  source_name String
  chunk_text  String
  embedding   Unsupported("vector(384)")?

  @@index([subject, year_group])
  @@map("curriculum_chunks")
}

// ---------- Curriculum coverage spine ----------

model CurriculumOutcome {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  framework_country      String   @default("England")
  framework_name         String   @default("National Curriculum 2014")
  key_stage              String   // "KS1", "KS2"
  year_group             String   // "Year 1" … "Year 6"
  subject                String   @default("Mathematics")
  domain                 String   // "Number – multiplication and division"
  statutory_outcome      String   // Full statutory statement text (verbatim)
  non_statutory_notes    String?
  source_reference       String   // Document + page reference + outcome code
  app_subject_id         String?  @db.Uuid
  app_topic_id           String?  @db.Uuid
  app_skill_id           String?  // e.g. "times_tables_recall" (text identifier, no FK)
  required_content_types String[] // ["learn","practice","quiz_sprout","quiz_explorer","quiz_lightning"]
  coverage_status        String   @default("unmapped")   // "mapped" | "partial" | "unmapped"
  verification_status    String   @default("unverified") // "verified" | "unverified" | "failed"
  created_at             DateTime @default(now())

  subject_ref Subject? @relation(fields: [app_subject_id], references: [id])
  topic_ref   Topic?   @relation(fields: [app_topic_id], references: [id])
  lessons     Lesson[]

  @@index([key_stage, year_group])
  @@index([app_topic_id])
  @@map("curriculum_outcomes")
}

// ---------- Lesson Store ----------
// Navigation/metadata layer on top of learn_content + practice_games + quiz_questions.
// Child-facing routes only show status='published' AND verification_status='verified'.

model Lesson {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subject_id            String        @db.Uuid
  topic_id              String        @db.Uuid
  curriculum_outcome_id String?       @db.Uuid
  title                 String
  slug                  String        @unique
  lesson_summary        String?
  learning_objective    String?
  key_stage             String
  year_group            String
  difficulty_lane       String?
  lesson_type           String?
  estimated_minutes     Int?
  app_experience        String?
  status                String        @default("staged")
  verification_method   String?
  verification_status   String        @default("unverified")
  source_reference      String?
  created_at            DateTime      @default(now())
  updated_at            DateTime      @updatedAt

  subject            Subject            @relation(fields: [subject_id], references: [id])
  topic              Topic              @relation(fields: [topic_id], references: [id])
  curriculum_outcome CurriculumOutcome? @relation(fields: [curriculum_outcome_id], references: [id])

  @@index([topic_id, status, verification_status])
  @@map("lessons")
}

// ---------- Reward Vault ----------

model VaultMilestone {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  band              String  @unique // 'bronze' | 'silver' | 'gold' | 'platinum'
  display_name      String
  xp_required       Int     @default(0)
  topics_required   Int     @default(0)
  badges_required   Int     @default(0)
  guardian_required Boolean @default(false)
  credits_awarded   Int     @default(1)
  order_index       Int
  is_active         Boolean @default(true)

  @@map("vault_milestones")
}

model ChildVaultStatus {
  profile_id              String    @id @db.Uuid
  current_band            String    @default("none")
  current_band_reached_at DateTime?
  credit_balance          Int       @default(0)
  credits_earned_total    Int       @default(0)
  last_milestone_check    DateTime  @default(now())

  profile Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@map("child_vault_status")
}

model VaultParentSettings {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parent_profile_id        String   @db.Uuid
  child_profile_id         String   @db.Uuid
  physical_rewards_enabled Boolean  @default(false)
  monthly_budget_pence     Int      @default(0)
  allowed_categories       String[] @default([])
  family_reward_options    Json     @default("[]")
  max_requests_per_month   Int      @default(1)
  delivery_address         Json?
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  parent Profile @relation("ParentVaultSettings", fields: [parent_profile_id], references: [id], onDelete: Cascade)
  child  Profile @relation("ChildVaultSettings", fields: [child_profile_id], references: [id], onDelete: Cascade)

  @@unique([parent_profile_id, child_profile_id])
  @@map("vault_parent_settings")
}

model RewardRequest {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  child_profile_id        String    @db.Uuid
  parent_profile_id       String    @db.Uuid
  responded_by_profile_id String?   @db.Uuid
  milestone_band          String
  xp_at_request           Int
  topics_at_request       Int
  badges_at_request       Int
  streak_at_request       Int       @default(0)
  child_message           String?
  credits_used            Int       @default(1)
  status                  String    @default("pending")
  parent_response_note    String?
  reward_type             String?
  reward_label            String?
  created_at              DateTime  @default(now())
  responded_at            DateTime?

  child        Profile       @relation("ChildRewardRequests", fields: [child_profile_id], references: [id], onDelete: Cascade)
  parent       Profile       @relation("ParentRewardRequests", fields: [parent_profile_id], references: [id])
  responded_by Profile?      @relation("RespondedByProfile", fields: [responded_by_profile_id], references: [id])
  fulfilment   RewardFulfilment?

  @@index([child_profile_id, status])
  @@index([parent_profile_id, created_at(sort: Desc)])
  @@map("reward_requests")
}

model VaultMilestoneEvent {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id      String   @db.Uuid
  band            String
  credits_awarded Int      @default(1)
  xp_snapshot     Int
  topics_snapshot Int
  occurred_at     DateTime @default(now())

  profile Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@index([profile_id, occurred_at(sort: Desc)])
  @@map("vault_milestone_events")
}

// Future-readiness tables — empty in Stage 1, populated in Stage 2+

model RewardCatalog {
  id                 String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  description        String?
  category           String?
  min_milestone      String?
  price_pence        Int     @default(0)
  image_url          String?
  shopify_variant_id String?
  is_active          Boolean @default(false)
  created_at         DateTime @default(now())

  @@map("reward_catalog")
}

model RewardFulfilment {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  request_id       String   @unique @db.Uuid
  status           String   @default("approved")
  shopify_order_id String?
  shopify_order_url String?
  tracking_number  String?
  admin_notes      String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  request RewardRequest @relation(fields: [request_id], references: [id])

  @@map("reward_fulfilments")
}

// ---------- Learning Events (PLI v1) ----------
// Lightweight behavioural events used by the parent signal engine.
// All writes go through lib/learning-events.ts — never from untrusted client input directly.

model LearningEvent {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id      String   @db.Uuid
  event_type      String   // lesson_opened | lesson_completed | lesson_repeated | lesson_exited_early
                           // | lesson_active_time_recorded | practice_started | practice_completed
                           // | quiz_started | quiz_completed | quiz_abandoned
                           // | recommendation_shown | recommendation_clicked | recommendation_ignored
  subject_id      String?  @db.Uuid
  topic_id        String?  @db.Uuid
  lesson_id       String?  @db.Uuid
  quiz_attempt_id String?  @db.Uuid
  metadata        Json     @default("{}")
  occurred_at     DateTime @default(now())

  profile Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@index([profile_id, event_type, occurred_at(sort: Desc)])
  @@index([profile_id, topic_id, occurred_at(sort: Desc)])
  @@map("learning_events")
}

// ---------- Daily challenge cache ----------

model DailyChallenge {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date          DateTime @db.Date
  year_group_id String   @db.Uuid
  question_ids  Json
  is_flare      Boolean  @default(false)

  year_group YearGroup @relation(fields: [year_group_id], references: [id])

  @@unique([date, year_group_id])
  @@map("daily_challenges")
}

// ---------- Question reports (Phase 12 — "Report a problem") ----------

model QuestionReport {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  question_id String   @db.Uuid
  profile_id  String   @db.Uuid
  reason      String
  status      String   @default("open")
  created_at  DateTime @default(now())

  question QuizQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)
  profile  Profile      @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@index([question_id])
  @@index([status])
  @@map("question_reports")
}

// ---------- Subscriptions (Stripe) ----------

model Subscription {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                String    @unique @db.Uuid // FK to auth.users
  stripe_customer_id     String?   @unique
  stripe_subscription_id String?   @unique
  plan                   String    @default("free") // 'free' | 'family'
  status                 String    @default("active") // 'active' | 'past_due' | 'canceled' | 'trialing'
  current_period_end     DateTime?
  cancel_at_period_end   Boolean   @default(false)
  trial_end              DateTime?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  @@index([stripe_customer_id])
  @@map("subscriptions")
}

// ---------- Learning Aid Box — exploration tracking ----------

model ExplorationSession {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id       String   @db.Uuid
  aid_type         String   // 'solar-system' | 'world-atlas' | 'human-body' | 'timeline' | 'periodic-table' | 'animal-kingdom'
  topic_key        String?  // specific item explored e.g. 'mars', 'france', 'heart'
  duration_seconds Int      @default(0)
  ask_count        Int      @default(0) // number of Ask Decifer questions asked
  created_at       DateTime @default(now())

  profile Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@index([profile_id])
  @@index([aid_type])
  @@map("exploration_sessions")
}

// ---------- Explorable engine (data-driven immersive explorers) ----------
// Content lives in the DB so new explorers need zero code (CLAUDE.md §16 r5).
// RLS enforces published-only reads (CLAUDE.md §8). See migration add_explorers.

model Explorer {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key          String         @unique
  title        String
  tagline      String?
  emoji        String?
  scene_type   String // 'orrery' | 'globe' | ...
  gradient     String?
  config       Json           @default("{}") // scene-wide settings (sun, starfield, camera)
  is_published Boolean        @default(false)
  order_index  Int            @default(0)
  created_at   DateTime       @default(now()) @db.Timestamptz(6)
  updated_at   DateTime       @default(now()) @updatedAt @db.Timestamptz(6)
  nodes        ExplorerNode[]

  @@index([is_published, order_index])
  @@map("explorers")
}

model ExplorerNode {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  explorer_id String   @db.Uuid
  key         String
  name        String
  order_index Int      @default(0)
  visual      Json     @default("{}") // color, radius, orbitRadius, period, texture, rings, wonderType
  stats       Json     @default("{}") // diameter, distanceFromSun, orbitalPeriod, moons
  content     Json     @default("{}") // description, fact, narration, layers[]
  quiz        Json? // question, options[], answer, explanation
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  explorer Explorer @relation(fields: [explorer_id], references: [id], onDelete: Cascade)

  @@unique([explorer_id, key])
  @@index([explorer_id, order_index])
  @@map("explorer_nodes")
}

// ---------- Exam Revision Mode ----------

model ExamAssignment {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parent_profile_id  String    @db.Uuid
  child_profile_id   String    @db.Uuid
  subject_id         String    @db.Uuid
  year_group_id      String    @db.Uuid
  title              String
  topic_scope        String    @default("all") // 'all' | 'weak_areas' | 'selected'
  topic_ids          Json?     // non-null when topic_scope='selected'
  question_count     Int       @default(20)
  time_limit_minutes Int       @default(30)
  hints_allowed      Boolean   @default(false)
  available_from     DateTime?
  available_until    DateTime?
  status             String    @default("active") // 'active' | 'completed' | 'archived'
  created_at         DateTime  @default(now())

  parent      Profile       @relation("ParentExamAssignments", fields: [parent_profile_id], references: [id], onDelete: Cascade)
  child       Profile       @relation("ChildExamAssignments", fields: [child_profile_id], references: [id], onDelete: Cascade)
  subject     Subject       @relation(fields: [subject_id], references: [id])
  year_group  YearGroup     @relation(fields: [year_group_id], references: [id])
  attempts    ExamAttempt[]

  @@index([child_profile_id, status])
  @@index([parent_profile_id, created_at(sort: Desc)])
  @@map("exam_assignments")
}

model ExamAttempt {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  exam_assignment_id  String    @db.Uuid
  profile_id          String    @db.Uuid
  question_ids        Json      // ordered array of question IDs served
  started_at          DateTime  @default(now())
  completed_at        DateTime?
  time_taken_seconds  Int?
  score               Float?    // 0.0–1.0
  status              String    @default("in_progress") // 'in_progress' | 'completed' | 'timed_out' | 'abandoned'
  answers             Json?     // [{questionId, childAnswer, wasCorrect, timeSeconds, topicId}]

  assignment  ExamAssignment @relation(fields: [exam_assignment_id], references: [id], onDelete: Cascade)
  profile     Profile        @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@index([exam_assignment_id])
  @@index([profile_id, started_at(sort: Desc)])
  @@map("exam_attempts")
}
