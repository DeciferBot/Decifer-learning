{
  "$schema": "https://deciferlearning.com/design-tokens/v2",
  "meta": {
    "version": "2.0.0",
    "product": "Decifer Learning",
    "tagline": "Where curious minds level up",
    "theme": "light-only",
    "updated": "2026-06-04",
    "fonts": {
      "display": "Nunito (400,500,600,700,800,900) — headings, labels, game UI",
      "body": "Inter (400,500,600,700) — body copy, parent dashboard",
      "mono": "JetBrains Mono (400,500) — maths expressions"
    }
  },

  "colors": {
    "core": {
      "background":  { "value": "#FAFBFF", "css": "--background",   "tw": "bg-background",  "usage": "App shell background — off-white with hint of blue" },
      "surface":     { "value": "#FFFFFF", "css": "--surface",       "tw": "bg-surface",     "usage": "Cards, modals, panels" },
      "surface-raised":{ "value": "#F7F9FF","css": "--surface-raised","tw": "bg-surface-raised","usage": "Slightly elevated from background" },
      "surface-sunken":{ "value": "#EDF2FF","css": "--surface-sunken","tw": "bg-surface-sunken","usage": "Input backgrounds, recessed areas" }
    },
    "subjects": {
      "maths":     { "value": "#6C9EFF", "bg": "#EEF3FF", "bdr": "#B8D0FF", "css": "--maths",    "usage": "Number Jungle, Crystal Labyrinth zones" },
      "english":   { "value": "#FF8FAB", "bg": "#FFF0F4", "bdr": "#FFB3C6", "css": "--english",  "usage": "Whispering Woods, Library of Echoes zones" },
      "science":   { "value": "#52D9A0", "bg": "#EDFDF5", "bdr": "#86EFBE", "css": "--science",  "usage": "Discovery Cave, Elemental Forge zones" },
      "history":   { "value": "#9B59B6", "bg": "#FAF5FF", "bdr": "#D8B4FE", "css": "--history",  "usage": "History curriculum topics" },
      "geography": { "value": "#F97316", "bg": "#FFF7ED", "bdr": "#FED7AA", "css": "--geography","usage": "Geography curriculum topics" }
    },
    "tiers": {
      "sprout":    { "value": "#A8E6CF", "css": "--sprout",    "usage": "Easiest difficulty tier badge" },
      "explorer":  { "value": "#74C0FC", "css": "--explorer",  "usage": "Mid difficulty tier badge" },
      "lightning": { "value": "#FFD43B", "css": "--lightning", "usage": "Hardest difficulty tier badge" }
    },
    "gamification": {
      "points-gold": { "value": "#FFC107", "css": "--points-gold", "usage": "XP totals, coin icons" },
      "xp":          { "value": "#FFC107", "css": "--xp",          "usage": "Alias of points-gold for semantic clarity" },
      "xp-bg":       { "value": "#FFFBEB", "css": "--xp-bg" },
      "streak":      { "value": "#FF6B35", "css": "--streak",      "usage": "Streak flame — distinct orange from --incorrect" },
      "streak-bg":   { "value": "#FFF4EF", "css": "--streak-bg" },
      "streak-at-risk": { "value": "#F59F00", "css": "--streak-at-risk", "usage": "Dim flame when streak at risk" },
      "correct":     { "value": "#40C057", "css": "--correct",     "usage": "Correct answer feedback, passed state" },
      "incorrect":   { "value": "#FF6B6B", "css": "--incorrect",   "usage": "Wrong answer feedback, error state" }
    },
    "rarity": {
      "common":    { "value": "#94A3B8", "bg": "#F1F5F9", "bdr": "#CBD5E1", "css": "--common",    "tier": 1 },
      "uncommon":  { "value": "#22C55E", "bg": "#F0FDF4", "bdr": "#86EFAC", "css": "--uncommon",  "tier": 2 },
      "rare":      { "value": "#3B82F6", "bg": "#EFF6FF", "bdr": "#93C5FD", "css": "--rare",      "tier": 3 },
      "epic":      { "value": "#A855F7", "bg": "#FAF5FF", "bdr": "#D8B4FE", "css": "--epic",      "tier": 4 },
      "legendary": { "value": "#F59E0B", "bg": "#FFFBEB", "bdr": "#FCD34D", "css": "--legendary", "tier": 5,
                     "gradient": "linear-gradient(135deg, #F59E0B 0%, #FBBF24 40%, #FEF08A 60%, #F59E0B 100%)" }
    },
    "semantic": {
      "success":    { "value": "#40C057", "bg": "#ECFDF5", "bdr": "#A3E6B8", "css": "--success" },
      "error":      { "value": "#FF6B6B", "bg": "#FFF5F5", "bdr": "#FFBDBD", "css": "--error" },
      "warning":    { "value": "#F59F00", "bg": "#FFFBEB", "bdr": "#FFE08A", "css": "--warning" },
      "info":       { "value": "#1C7ED6", "bg": "#EBF5FF", "bdr": "#A5C8F0", "css": "--info" },
      "guardian":   { "value": "#5C3B8B", "bg": "#F3EEFF", "bdr": "#C4B0E8", "dark": "#2D1B4E", "css": "--guardian", "usage": "Boss UI only — never in regular content" }
    },
    "borders": {
      "default": { "value": "#E2E8F4", "css": "--border-default" },
      "strong":  { "value": "#CBD5E8", "css": "--border-strong" },
      "focus":   { "value": "#4A7FD4", "css": "--border-focus", "contrast": "3.1:1 on white — passes WCAG AA 3:1 for UI" }
    },
    "text": {
      "heading":     { "value": "#1A202C", "css": "--text-heading",     "contrast": "15.3:1 on --background" },
      "primary":     { "value": "#2D3748", "css": "--text-primary",     "contrast": "11.8:1 on --background" },
      "secondary":   { "value": "#4A5568", "css": "--text-secondary",   "contrast": "7.4:1 on --background" },
      "muted":       { "value": "#666666", "css": "--text-muted",       "contrast": "5.74:1 on --background — passes AA" },
      "placeholder": { "value": "#A0AEC0", "css": "--text-placeholder", "contrast": "2.9:1 — decorative only, not used for meaning" },
      "disabled":    { "value": "#CBD5E0", "css": "--text-disabled" },
      "inverse":     { "value": "#FFFFFF", "css": "--text-inverse",     "usage": "On coloured or dark backgrounds" },
      "link":        { "value": "#1C7ED6", "css": "--text-link" },
      "link-hover":  { "value": "#1558A8", "css": "--text-link-hover" }
    }
  },

  "typography": {
    "fonts": {
      "display": { "value": "'Nunito', system-ui, sans-serif", "css": "--font-display", "weights": [400,500,600,700,800,900] },
      "body":    { "value": "'Inter', system-ui, sans-serif",  "css": "--font-body",    "weights": [400,500,600,700] },
      "mono":    { "value": "'JetBrains Mono', 'Fira Code', monospace", "css": "--font-mono", "weights": [400,500] }
    },
    "scale": [
      { "step": "display-xl", "px": 72, "rem": "4.5rem", "lh": 1.0,  "fw": 900, "ls": "-0.03em", "ff": "display", "usage": "Celebration screens, point totals, HP counters" },
      { "step": "display-lg", "px": 56, "rem": "3.5rem", "lh": 1.1,  "fw": 800, "ls": "-0.02em", "ff": "display", "usage": "Zone Guardian HP, card rarity, zone names" },
      { "step": "h1",         "px": 36, "rem": "2.25rem","lh": 1.15, "fw": 800, "ls": "-0.02em", "ff": "display", "usage": "Page titles" },
      { "step": "h2",         "px": 28, "rem": "1.75rem","lh": 1.2,  "fw": 700, "ls": "-0.01em", "ff": "display", "usage": "Section headers, zone names" },
      { "step": "h3",         "px": 22, "rem": "1.375rem","lh": 1.3, "fw": 700, "ls": "0em",     "ff": "display", "usage": "Card titles, topic names" },
      { "step": "h4",         "px": 18, "rem": "1.125rem","lh": 1.4, "fw": 600, "ls": "0em",     "ff": "body",    "usage": "Parent dashboard widget headers" },
      { "step": "label-lg",   "px": 16, "rem": "1rem",   "lh": 1.4,  "fw": 700, "ls": "0.01em",  "ff": "display", "usage": "Primary button text, tab labels" },
      { "step": "label-md",   "px": 14, "rem": "0.875rem","lh": 1.4, "fw": 700, "ls": "0.01em",  "ff": "display", "usage": "Secondary buttons, chip labels, badge names" },
      { "step": "label-sm",   "px": 12, "rem": "0.75rem","lh": 1.4,  "fw": 600, "ls": "0.02em",  "ff": "display", "usage": "Meta text, timestamps, tier labels" },
      { "step": "body-lg",    "px": 18, "rem": "1.125rem","lh": 1.7, "fw": 400, "ls": "0em",     "ff": "body",    "usage": "Learn page body copy (child)" },
      { "step": "body-md",    "px": 16, "rem": "1rem",   "lh": 1.65, "fw": 400, "ls": "0em",     "ff": "body",    "usage": "Quiz questions — most-read text. Min 16px at 375px." },
      { "step": "body-sm",    "px": 14, "rem": "0.875rem","lh": 1.6, "fw": 400, "ls": "0em",     "ff": "body",    "usage": "Hint text, explanation text" },
      { "step": "caption",    "px": 12, "rem": "0.75rem","lh": 1.5,  "fw": 400, "ls": "0em",     "ff": "body",    "usage": "Image captions, footer notes" },
      { "step": "code",       "px": 14, "rem": "0.875rem","lh": 1.6, "fw": 400, "ls": "0em",     "ff": "mono",    "usage": "Maths expressions only" }
    ]
  },

  "spacing": {
    "note": "4 px base grid. All values are multiples of 4.",
    "scale": [
      { "step": "1",  "value": "4px",  "css": "--space-1"  },
      { "step": "2",  "value": "8px",  "css": "--space-2"  },
      { "step": "3",  "value": "12px", "css": "--space-3"  },
      { "step": "4",  "value": "16px", "css": "--space-4"  },
      { "step": "5",  "value": "20px", "css": "--space-5"  },
      { "step": "6",  "value": "24px", "css": "--space-6"  },
      { "step": "8",  "value": "32px", "css": "--space-8"  },
      { "step": "10", "value": "40px", "css": "--space-10" },
      { "step": "12", "value": "48px", "css": "--space-12" },
      { "step": "16", "value": "64px", "css": "--space-16" },
      { "step": "20", "value": "80px", "css": "--space-20" },
      { "step": "24", "value": "96px", "css": "--space-24" }
    ]
  },

  "radii": {
    "sm":     { "value": "8px",   "css": "--radius-sm" },
    "chip":   { "value": "8px",   "css": "--radius-chip" },
    "input":  { "value": "12px",  "css": "--radius-input" },
    "button": { "value": "12px",  "css": "--radius-button" },
    "card":   { "value": "16px",  "css": "--radius-card" },
    "lg":     { "value": "20px",  "css": "--radius-lg" },
    "modal":  { "value": "24px",  "css": "--radius-modal" },
    "xl":     { "value": "28px",  "css": "--radius-xl" },
    "pill":   { "value": "999px", "css": "--radius-pill" },
    "avatar": { "value": "50%",   "css": "--radius-avatar" }
  },

  "shadows": {
    "elevation-0": { "value": "none",                                                                                          "css": "none",             "usage": "Flat elements on --surface" },
    "elevation-1": { "value": "0 1px 3px rgba(66,100,200,0.08), 0 1px 2px rgba(66,100,200,0.04)",                            "css": "--shadow-card",    "usage": "Cards at rest" },
    "elevation-2": { "value": "0 4px 12px rgba(66,100,200,0.12), 0 2px 4px rgba(66,100,200,0.06)",                           "css": "--shadow-hover",   "usage": "Card hover, press-start" },
    "elevation-3": { "value": "0 2px 8px rgba(66,100,200,0.10), 0 1px 3px rgba(66,100,200,0.06)",                            "css": "--shadow-sticky",  "usage": "Bottom tab bar, sticky headers" },
    "elevation-4": { "value": "0 8px 24px rgba(66,100,200,0.16), 0 3px 8px rgba(66,100,200,0.08)",                           "css": "--shadow-elevated","usage": "Modals, drawers" },
    "elevation-5": { "value": "0 12px 32px rgba(66,100,200,0.18), 0 4px 12px rgba(66,100,200,0.10)",                         "css": "--shadow-toast",   "usage": "Toasts, tooltips" }
  },

  "zIndex": {
    "base":     { "value": 0,   "css": "--z-base"     },
    "raised":   { "value": 10,  "css": "--z-raised"   },
    "sticky":   { "value": 100, "css": "--z-sticky"   },
    "dropdown": { "value": 200, "css": "--z-dropdown" },
    "overlay":  { "value": 300, "css": "--z-overlay"  },
    "modal":    { "value": 400, "css": "--z-modal"    },
    "toast":    { "value": 500, "css": "--z-toast"    },
    "top":      { "value": 999, "css": "--z-top"      }
  },

  "icons": {
    "xs":  { "value": "16px", "css": "--icon-xs", "usage": "Inline icons, tight spaces" },
    "sm":  { "value": "20px", "css": "--icon-sm", "usage": "Secondary UI icons" },
    "md":  { "value": "24px", "css": "--icon-md", "usage": "Standard Lucide default" },
    "lg":  { "value": "32px", "css": "--icon-lg", "usage": "Feature icons, empty states" },
    "xl":  { "value": "48px", "css": "--icon-xl", "usage": "Guardian screen, illustration-scale" },
    "tapTarget": { "value": "48px", "note": "All interactive icons must have a 48×48px tap target" },
    "strokeWidth": { "value": "2px", "note": "Standard for all Lucide icons" }
  },

  "motion": {
    "durations": {
      "instant":  { "value": "80ms",  "css": "--duration-instant",  "usage": "Tap feedback, border-colour swaps" },
      "fast":     { "value": "150ms", "css": "--duration-fast",     "usage": "Button states, chip toggles" },
      "normal":   { "value": "250ms", "css": "--duration-normal",   "usage": "Card transitions, drawer open" },
      "slow":     { "value": "400ms", "css": "--duration-slow",     "usage": "Page transitions, modal appear" },
      "dramatic": { "value": "800ms", "css": "--duration-dramatic", "usage": "Card reveal, boss appear, level-up" }
    },
    "easings": {
      "out-back":  { "value": "cubic-bezier(0.34, 1.56, 0.64, 1)",   "css": "--ease-out-back",  "usage": "Elements that pop — correct tick, badge award" },
      "spring":    { "value": "cubic-bezier(0.175, 0.885, 0.32, 1.275)", "css": "--ease-spring","usage": "Character/avatar movements" },
      "in-out":    { "value": "cubic-bezier(0.45, 0.00, 0.55, 1.00)", "css": "--ease-in-out",   "usage": "Page transitions" },
      "out-expo":  { "value": "cubic-bezier(0.16, 1.00, 0.30, 1.00)", "css": "--ease-out-expo", "usage": "Overlays entering" },
      "out":       { "value": "cubic-bezier(0.22, 1.00, 0.36, 1.00)", "css": "--ease-out",      "usage": "Shadows, fades" }
    }
  },

  "breakpoints": {
    "mobile":  { "value": "375px",  "usage": "Primary design target — iPhone SE" },
    "phablet": { "value": "428px",  "usage": "iPhone 14 Pro Max" },
    "tablet":  { "value": "768px",  "usage": "iPad mini — sidebar nav appears" },
    "desktop": { "value": "1024px", "usage": "Parent/admin dashboard secondary target" }
  }
}
