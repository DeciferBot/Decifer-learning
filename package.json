{
  "name": "decifer-learning",
  "version": "2.9.0",
  "private": true,
  "description": "Decifer Learning — UK National Curriculum PWA. See CLAUDE.md.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "verify-content-freshness-safety": "node scripts/verify-content-freshness-safety.mjs",
    "verify-content-safety": "node scripts/verify-content-safety.mjs",
    "verify-phase8": "node scripts/verify-phase8.mjs",
    "verify-phase8a": "node scripts/verify-phase8a.mjs",
    "verify-parent-dashboard-safety": "node scripts/verify-parent-dashboard-safety.mjs",
    "verify-lesson-store-safety": "node --env-file=.env.local scripts/verify-lesson-store-safety.mjs",
    "audit:widgets": "npx tsx scripts/audit-widget-configs.ts",
    "audit:widgets:fix": "npx tsx scripts/audit-widget-configs.ts --fix",
    "verify-pli": "node scripts/verify-parent-learning-intelligence.mjs",
    "verify-autopilot-safety": "node scripts/verify-autopilot-safety.mjs",
    "verify-autopilot-2b2-safety": "node scripts/verify-autopilot-2b2-safety.mjs",
    "learning:worked-examples": "node --env-file=.env.local scripts/generate-worked-examples.mjs",
    "learning:worked-examples:dry": "node --env-file=.env.local scripts/generate-worked-examples.mjs --dry-run",
    "learning:autopilot:plan": "node --env-file=.env.local scripts/learning-autopilot-plan.mjs",
    "learning:autopilot:queue": "/root/pipeline-venv/bin/python3 scripts/learning-autopilot-queue.py",
    "learning:autopilot:run": "/root/pipeline-venv/bin/python3 scripts/learning-autopilot-run.py",
    "vault:seed": "node --env-file=.env.local scripts/seed-vault-catalogue.mjs",
    "vault:seed:activate": "node --env-file=.env.local scripts/seed-vault-catalogue.mjs --activate",
    "vault:seed:dry": "node --env-file=.env.local scripts/seed-vault-catalogue.mjs --dry-run",
    "verify-vault-safety": "node --env-file=.env.local scripts/verify-reward-vault-safety.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.101.0",
    "@next/third-parties": "^16.2.6",
    "@prisma/client": "^5.22.0",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.17.10",
    "@stripe/stripe-js": "^9.7.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "framer-motion": "^11.11.0",
    "geist": "^1.7.2",
    "idb": "^8.0.0",
    "katex": "^0.17.0",
    "next": "14.2.35",
    "next-pwa": "^5.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-katex": "^3.1.0",
    "resend": "^6.12.4",
    "stripe": "^22.2.0",
    "three": "^0.184.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.184.1",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18.17"
  }
}
